# ── Database ─────────────────────────────────────────────────────────────────
# Supabase transaction pooler (port 6543) — used by Prisma Client at runtime.
# ?pgbouncer=true disables prepared statements, required for PgBouncer transaction mode.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Supabase session pooler or direct connection (port 5432) — used by Prisma Migrate.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Allowed origin for CORS (set to your frontend URL in production)
CORS_ORIGIN="http://localhost:5173"

# ── LLM tuning ────────────────────────────────────────────────────────────────
# Model to use — haiku is recommended for cost/speed; swap to claude-sonnet-4-6 for higher quality
LLM_MODEL=claude-haiku-4-5-20251001

# Number of prior messages sent to the LLM for context (token budget control)
MAX_HISTORY_MESSAGES=12
# Max tokens the LLM may generate per reply
LLM_MAX_TOKENS=1024
# Milliseconds before we abort an LLM call and retry/fail
LLM_TIMEOUT_MS=30000
