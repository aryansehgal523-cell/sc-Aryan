{
  "name": "@spur-chat/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate",
    "start": "prisma migrate deploy && tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^5.15.0",
    "@spur-chat/shared": "*",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.16.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prisma": "^5.15.0",
    "typescript": "^5.4.5"
  }
}
